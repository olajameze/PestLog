# Copy to .env.local and fill in values. Never commit real secrets.

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Postgres — Vercel/serverless: pooler TRANSACTION mode (port 6543) + pgbouncer=true for Prisma.
# If Supabase UI offers method=transaction on the pooler URL, use that for DATABASE_URL.
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1

# Direct Postgres for Prisma CLI / migrations (port 5432, db host). Fine from your laptop; often P1001 from
# Vercel/AWS build networks (IPv6 / routing). Default `npm run build` on Vercel is Next-only — run migrations separately.
DIRECT_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# One-off SQL (not Prisma models): `npm run db:sync-audit-logs` creates public.audit_logs if missing.
#
# When DIRECT_URL is unreachable (P1001), use Session pooler on port 5432 for `prisma migrate` / `db execute`
# (Supabase → Connect → Session mode). Optionally set on Vercel only if you use `npm run build:migrate` as
# Install Command override and a pooler URL here — not `db.*.supabase.co`.
# PRISMA_CLI_DATABASE_URL="postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# Stripe (optional for billing routes)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Subscription checkout — Price IDs from Stripe Dashboard → Products (mode must match STRIPE_SECRET_KEY)
STRIPE_PRICE_ID_PRO=price_...
STRIPE_PRICE_ID_BUSINESS=price_1TTguILNmoX4GCc1y6ZvnUIx
STRIPE_PRICE_ID_ENTERPRISE=price_1TTgvVLNmoX4GCc1h4DsdPYv
# Customer portal return URL — must be absolute (https://…). Invalid values are ignored (app uses
# request host / NEXT_PUBLIC_APP_URL / production URL). Stripe → Customer portal settings must list
# domains you use (add https://*.vercel.app for preview deployments if needed).
# Must be ONE URL string only — no spaces, parentheses, or notes (wrong: "...com (no /home)/dashboard").
# STRIPE_PORTAL_RETURN_URL=https://www.example.com/dashboard?tab=settings
# Optional — if Stripe requires an explicit portal configuration (bpc_…) for your account:
# STRIPE_BILLING_PORTAL_CONFIGURATION_ID=bpc_...

# Web Push (PWA / mobile-friendly browsers) — device alerts when the app is in the background
# Generate keys locally: npx web-push generate-vapid-keys
# Public → NEXT_PUBLIC_* (embedded in the browser bundle). Private → server-only (never NEXT_PUBLIC_*).
NEXT_PUBLIC_WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
# Optional contact URI for push services (often mailto:). Falls back if SUPPORT_EMAIL is set server-side.
# WEB_PUSH_VAPID_SUBJECT=mailto:admin@yourdomain.com
#
# --- Vercel / production (or any host) ---
# 1) Run: npx web-push generate-vapid-keys — copy Public Key and Private Key.
# 2) Dashboard → Project → Settings → Environment Variables:
#    - NEXT_PUBLIC_WEB_PUSH_VAPID_PUBLIC_KEY = (public string)
#    - WEB_PUSH_VAPID_PRIVATE_KEY = (private string; mark “Sensitive” if offered)
#    Optionally: WEB_PUSH_VAPID_SUBJECT=mailto:support@yourdomain.com
# 3) Scope: enable at least “Production”. Add “Preview” only if you want push on *.vercel.app previews.
# 4) Redeploy the project so the client bundle picks up NEXT_PUBLIC_* values.

# Super admin (platform operator only)
# Use double quotes if password or secret contains # or spaces (unquoted # starts a comment in .env).
SUPER_ADMIN_EMAIL=super-admin@example.com
SUPER_ADMIN_PASSWORD="change-me-in-.env.local"
SUPER_ADMIN_SESSION_SECRET="use-at-least-16-random-chars"
# Optional: separate secret for intelligence row fingerprints (defaults to SUPER_ADMIN_SESSION_SECRET if unset)
# INTELLIGENCE_SOURCE_SECRET=another_long_random_secret

# App URL (auth redirects, emails)
# Local — must match the host you use in the browser (critical for email links and OTP resend):
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase Auth → URL configuration → Redirect URLs (add production hosts too):
# - http://localhost:3000/auth/callback
# - http://localhost:3000/dashboard
# - https://YOUR_PRODUCTION_DOMAIN/auth/callback
# - https://YOUR_PRODUCTION_DOMAIN/dashboard
#
# Email templates (Dashboard → Authentication → Email):
# - Confirm signup: link-based for signUp confirmation (no {{ .Token }} required for step 1).
# - Magic link (OTP / signInWithOtp): include the code, e.g. <p>Please enter this code: {{ .Token }}</p>
# - Reset password: link-based (typically no {{ .Token }}).
# See https://supabase.com/docs/guides/auth/auth-email-templates
# Details: docs/SUPABASE_AUTH_SETUP.md

# Maintenance mode (set true to show /maintenance to all app users)
MAINTENANCE_MODE=false
# Optional logger override: info | warn | error | silent
LOG_LEVEL=warn
# Advanced field tools feature flags
NEXT_PUBLIC_ENABLE_VOICE_NOTES=false
NEXT_PUBLIC_ENABLE_PHOTO_ANNOTATION=false

# Production (Vercel) — PestTrace live host (example: www.pesttrace.com)
#
# Use the site ORIGIN only (no path). The marketing site is served at https://www.pesttrace.com/ — do not append
# paths here; billing + siteOrigin.ts normalise to origin only (https://www.pesttrace.com).
# Uncomment and set in Vercel → Settings → Environment Variables (Production):
# NEXTAUTH_URL=https://www.pesttrace.com
# NEXT_PUBLIC_APP_URL=https://www.pesttrace.com
# NEXT_PUBLIC_SITE_URL=https://www.pesttrace.com
#
# Stripe (live): webhook endpoint — https://www.pesttrace.com/api/webhooks/stripe
# Stripe Dashboard → Customer portal: allow domain https://www.pesttrace.com
#
# Supabase Auth → Redirect URLs — include at least:
# - https://www.pesttrace.com/auth/callback
# - https://www.pesttrace.com/dashboard
#
# Vercel Preview: manifest + middleware redirect use VERCEL_PROJECT_PRODUCTION_URL (auto) and/or:
# NEXT_PUBLIC_APP_URL / NEXT_PUBLIC_SITE_URL / NEXT_PUBLIC_MANIFEST_ORIGIN

# Load @vercel/analytics only when Web Analytics is enabled for the project (avoids /_vercel/insights 404 noise)
# NEXT_PUBLIC_VERCEL_ANALYTICS_ENABLED=true

# Email (Resend)
RESEND_API_KEY=re_...
# Use a verified domain as sender for production — required for reliable delivery to e.g.
# Outlook/Hotmail. onboarding@resend.dev is sandbox-limited for testing only.
RESEND_FROM_EMAIL=onboarding@resend.dev
# After sending, inspect delivery in Resend → Logs (use resendId from API responses when enabled).
# Support inbox used for reply-to and customer contact links; /api/contact delivers submissions here via Resend.
SUPPORT_EMAIL=pesttrace@gmail.com

# OTP auth UX tuning (technician sign-in + admin signup verification)
NEXT_PUBLIC_OTP_RESEND_COOLDOWN_SECONDS=30

# Supabase Auth requirement:
# Configure Supabase Auth SMTP to route through your Resend domain mailbox.
# OTP/magic-link delivery for signInWithOtp uses Supabase SMTP, not this app's direct mailer.
