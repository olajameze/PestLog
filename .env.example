# Copy to .env.local and fill in values. Never commit real secrets.

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Postgres — Vercel/serverless: pooler TRANSACTION mode (port 6543) + pgbouncer=true for Prisma.
# If Supabase UI offers method=transaction on the pooler URL, use that for DATABASE_URL.
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1

# Direct Postgres for Prisma CLI / migrations only (port 5432, db host)
DIRECT_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# If Prisma CLI cannot reach DIRECT_URL (P1001 / port 5432 blocked), set this for local `prisma db execute`.
# Prefer Supabase Session pooler: port 5432 on *.pooler.supabase.com (see Supabase → Connect → Session pooler).
# Transaction pooler (6543) often hangs or errors with `prisma db execute`.
# PRISMA_CLI_DATABASE_URL="postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# Stripe (optional for billing routes)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Subscription checkout — Price IDs from Stripe Dashboard → Products (mode must match STRIPE_SECRET_KEY)
STRIPE_PRICE_ID_PRO=price_...
STRIPE_PRICE_ID_BUSINESS=price_1TTguILNmoX4GCc1y6ZvnUIx
STRIPE_PRICE_ID_ENTERPRISE=price_1TTgvVLNmoX4GCc1h4DsdPYv

# Web Push (PWA / mobile-friendly browsers) — device alerts when the app is in the background
# Generate a key pair: npx web-push generate-vapid-keys
# Put the public key in both vars below; private key must stay server-only (never NEXT_PUBLIC_*).
NEXT_PUBLIC_WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
# Optional; defaults to mailto:SUPPORT_EMAIL when set
# WEB_PUSH_VAPID_SUBJECT=mailto:admin@yourdomain.com

# Super admin (platform operator only)
SUPER_ADMIN_EMAIL=super-admin@yourdomain.com
SUPER_ADMIN_PASSWORD=change_me
SUPER_ADMIN_SESSION_SECRET=replace_with_long_random_secret

# App URL (auth redirects, emails)
# Local — must match the host you use in the browser (critical for email links and OTP resend):
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase Auth → URL configuration → Redirect URLs (add production hosts too):
# - http://localhost:3000/auth/callback
# - http://localhost:3000/dashboard
# - https://YOUR_PRODUCTION_DOMAIN/auth/callback
# - https://YOUR_PRODUCTION_DOMAIN/dashboard
#
# Email templates (Dashboard → Authentication → Email):
# - Confirm signup: link-based for signUp confirmation (no {{ .Token }} required for step 1).
# - Magic link (OTP / signInWithOtp): include the code, e.g. <p>Please enter this code: {{ .Token }}</p>
# - Reset password: link-based (typically no {{ .Token }}).
# See https://supabase.com/docs/guides/auth/auth-email-templates
# Details: docs/SUPABASE_AUTH_SETUP.md

# Maintenance mode (set true to show /maintenance to all app users)
MAINTENANCE_MODE=false
# Optional logger override: info | warn | error | silent
LOG_LEVEL=warn
# Advanced field tools feature flags
NEXT_PUBLIC_ENABLE_VOICE_NOTES=false
NEXT_PUBLIC_ENABLE_PHOTO_ANNOTATION=false

# Production (Vercel):
# Include https:// (Stripe checkout success/cancel URLs require a valid absolute origin).
# NEXTAUTH_URL=https://www.pesttrace.com
# NEXT_PUBLIC_APP_URL=https://www.pesttrace.com
# NEXT_PUBLIC_SITE_URL=https://www.pesttrace.com
#
# Vercel Preview + Deployment Protection: anonymous requests (e.g. /manifest.json) return 401 on *.vercel.app.
# Duplicate NEXT_PUBLIC_APP_URL (or NEXT_PUBLIC_SITE_URL / NEXT_PUBLIC_MANIFEST_ORIGIN) for the Preview
# environment to your canonical https://… origin so manifest + PWA work on preview deployments.
# NEXT_PUBLIC_MANIFEST_ORIGIN=https://www.pesttrace.com

# Load @vercel/analytics only when Web Analytics is enabled for the project (avoids /_vercel/insights 404 noise)
# NEXT_PUBLIC_VERCEL_ANALYTICS_ENABLED=true

# Email (Resend)
RESEND_API_KEY=re_...
# Use a verified sender/domain in production. For testing, onboarding@resend.dev works.
RESEND_FROM_EMAIL=onboarding@resend.dev
# Support inbox used for reply-to and customer contact links.
SUPPORT_EMAIL=pesttrace@gmail.com

# OTP auth UX tuning (technician sign-in + admin signup verification)
NEXT_PUBLIC_OTP_RESEND_COOLDOWN_SECONDS=30

# Supabase Auth requirement:
# Configure Supabase Auth SMTP to route through your Resend domain mailbox.
# OTP/magic-link delivery for signInWithOtp uses Supabase SMTP, not this app's direct mailer.
