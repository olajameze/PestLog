    "load:health": "node scripts/concurrent-health-smoke.js",
    "e2e": "npx playwright test",
    "e2e:webhook": "npx playwright test tests/stripe-webhook.spec.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
