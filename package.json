    "@supabase/auth-helpers-nextjs": "^0.15.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.3",
    "@vercel/analytics": "^2.0.1",
    "framer-motion": "^12.38.0",
    "idb": "^8.0.3",
    "idb-keyval": "^6.2.2",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.8.0",
    "micro": "^10.0.1",
    "next": "^16.2.4",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.0",
    "stripe": "^22.0.0",
    "web-push": "^3.6.7"
