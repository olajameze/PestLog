generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas = ["public"]
}

model Company {
  @@map("Company")
  @@schema("public")
  id                      String         @id @default(cuid())
  name                    String?
  email                   String         @unique
  phone                   String?
  address                 String?
  website                 String?
  vatNumber               String?
  requireSignature        Boolean        @default(false)
  requirePhotos           Boolean        @default(false)
  defaultReportRangeDays  Int?           @default(30)
  notificationPreferences Json?
  stripeCustomerId        String?        @unique
  subscriptionStatus      String         @default("trial")
  trialEndsAt             DateTime?
  plan                    String?        @default("trial")
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  technicians             Technician[]
  logbookEntries          LogbookEntry[]
}

model Technician {
  @@map("Technician")
  @@schema("public")
  id                      String                   @id @default(cuid())
  name                    String
  email                   String
  companyId               String
  createdAt               DateTime                 @default(now())
  company                 Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  certifications          Certification[]
  logbookEntryTechnicians LogbookEntryTechnician[]
}

model Certification {
  @@map("Certification")
  @@schema("public")
  id           String     @id @default(cuid())
  technicianId String
  fileUrl      String
  expiryDate   DateTime?
  uploadedAt   DateTime   @default(now())
  technician   Technician @relation(fields: [technicianId], references: [id], onDelete: Cascade)
}

model LogbookEntry {
  @@map("LogbookEntry")
  @@schema("public")
  id                      String                   @id @default(cuid())
  companyId               String
  date                    DateTime
  clientName              String
  address                 String
  treatment               String
  notes                   String?
  photoUrl                String?
  photos                  LogbookPhoto[]
  signature               String?
  rooms                   Json? // ["Kitchen", "Garage"]
  baitBoxesPlaced         String? // "Yes, 6 boxes" or "No"
  poisonUsed              String? // "Bromadiolone" or "No"
  followUpDate              DateTime?
  internalNotes             String?
  productAmount             String?
  recommendation            String?
  baitStations              BaitStation[]
  startTime               DateTime?
  endTime                 DateTime?
  status                  String                   @default("open")
  price                   Decimal?                 // Job price for CLV calculations
  logbookEntryTechnicians LogbookEntryTechnician[]
  createdAt               DateTime                 @default(now())
  company                 Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model BaitStation {
  @@map("BaitStation")
  @@schema("public")
  id             String       @id @default(cuid())
  logbookEntryId String
  stationId      String
  location       String
  baitType       String?
  amount         String?
  createdAt      DateTime     @default(now())
  logbookEntry   LogbookEntry @relation(fields: [logbookEntryId], references: [id], onDelete: Cascade)
}

model LogbookEntryTechnician {
  @@map("LogbookEntryTechnician")
  @@schema("public")
  logbookEntryId String
  technicianId   String
  logbookEntry   LogbookEntry @relation(fields: [logbookEntryId], references: [id], onDelete: Cascade)
  technician     Technician   @relation(fields: [technicianId], references: [id], onDelete: Cascade)

  @@id([logbookEntryId, technicianId])
}

model LogbookPhoto {
  @@map("LogbookPhoto")
  @@schema("public")
  id             String       @id @default(cuid())
  logbookEntryId String
  url            String
  createdAt      DateTime     @default(now())
  logbookEntry   LogbookEntry @relation(fields: [logbookEntryId], references: [id], onDelete: Cascade)
}


