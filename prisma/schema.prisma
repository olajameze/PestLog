// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
}

model Company {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  stripeCustomerId String? @unique
  subscriptionStatus String @default("trial") // trial, active, canceled, past_due
  trialEndsAt   DateTime? // 14 days after signup
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  technicians   Technician[]
  logbookEntries LogbookEntry[]
}

model Technician {
  id        String   @id @default(cuid())
  name      String
  email     String
  companyId String
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  certifications Certification[]
  logbookEntries LogbookEntry[]
}

model Certification {
  id            String   @id @default(cuid())
  technicianId  String
  fileUrl       String   // Supabase Storage URL
  expiryDate    DateTime? // optional
  uploadedAt    DateTime @default(now())

  technician Technician @relation(fields: [technicianId], references: [id], onDelete: Cascade)
}

model LogbookEntry {
  id            String   @id @default(cuid())
  companyId     String
  technicianId  String
  date          DateTime
  clientName    String
  address       String
  treatment     String
  notes         String?
  photoUrl      String?  // optional photo
  signature     String?  // base64 or text "Signed by [client]"
  createdAt     DateTime @default(now())

  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  technician Technician @relation(fields: [technicianId], references: [id], onDelete: Cascade)
}
