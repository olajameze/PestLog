generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Company {
  id                      String         @id @default(cuid())
  name                    String?
  email                   String         @unique
  phone                   String?
  address                 String?
  website                 String?
  vatNumber               String?
  requireSignature        Boolean        @default(false)
  requirePhotos           Boolean        @default(false)
  defaultReportRangeDays  Int?           @default(30)
  notificationPreferences Json?
  stripeCustomerId        String?        @unique
  subscriptionStatus      String         @default("trial")
  trialEndsAt             DateTime?
  plan                    String?        @default("trial")
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  technicians             Technician[]
  logbookEntries          LogbookEntry[]
  chemicalInventory       ChemicalInventory[]
  marketingSpend          MarketingSpend[]
}

model Technician {
  id                      String                   @id @default(cuid())
  name                    String
  email                   String
  companyId               String
  createdAt               DateTime                 @default(now())
  company                 Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  certifications          Certification[]
  logbookEntryTechnicians LogbookEntryTechnician[]
}

model Certification {
  id           String     @id @default(cuid())
  technicianId String
  fileUrl      String
  expiryDate   DateTime?
  uploadedAt   DateTime   @default(now())
  technician   Technician @relation(fields: [technicianId], references: [id], onDelete: Cascade)
}

model LogbookEntry {
  id                      String                   @id @default(cuid())
  companyId               String
  date                    DateTime
  clientName              String
  address                 String
  treatment               String
  notes                   String?
  photoUrl                String?
  photos                  LogbookPhoto[]
  signature               String?
  rooms                   Json? // ["Kitchen", "Garage"]
  baitBoxesPlaced         String? // "Yes, 6 boxes" or "No"
  poisonUsed              String? // "Bromadiolone" or "No"
  followUpDate              DateTime?
  internalNotes             String?
  productAmount             String?
  recommendation            String?
  baitStations              BaitStation[]
  startTime               DateTime?
  endTime                 DateTime?
  status                  String                   @default("open")
  price                   Decimal?                 // Job price for CLV calculations
  latitude                Float?                   // GPS coordinates for accurate mapping
  longitude               Float?                   // GPS coordinates for accurate mapping
  logbookEntryTechnicians LogbookEntryTechnician[]
  createdAt               DateTime                 @default(now())
  company                 Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model BaitStation {
  id             String       @id @default(cuid())
  logbookEntryId String
  stationId      String
  location       String
  baitType       String?
  amount         String?
  createdAt      DateTime     @default(now())
  logbookEntry   LogbookEntry @relation(fields: [logbookEntryId], references: [id], onDelete: Cascade)
}

model LogbookEntryTechnician {
  logbookEntryId String
  technicianId   String
  logbookEntry   LogbookEntry @relation(fields: [logbookEntryId], references: [id], onDelete: Cascade)
  technician     Technician   @relation(fields: [technicianId], references: [id], onDelete: Cascade)

  @@id([logbookEntryId, technicianId])
}

model LogbookPhoto {
  id             String       @id @default(cuid())
  logbookEntryId String
  url            String
  createdAt      DateTime     @default(now())
  logbookEntry   LogbookEntry @relation(fields: [logbookEntryId], references: [id], onDelete: Cascade)
}

model ChemicalInventory {
  id           String   @id @default(cuid())
  companyId    String
  chemicalName String
  currentStock Float    // Current stock level in ml/liters
  unit         String   @default("ml") // ml, liters, kg, etc.
  reorderPoint Float?  // Minimum stock level before reorder alert
  supplier     String?
  batchNumber  String?
  expiryDate   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, chemicalName])
}

model MarketingSpend {
  id          String   @id @default(cuid())
  companyId   String
  amount      Decimal  // Marketing spend amount
  currency    String   @default("GBP")
  category    String   // "Google Ads", "Facebook", "SEO", "Events", etc.
  description String?
  date        DateTime // When the spend occurred
  period      String?  // "monthly", "quarterly", etc.
  createdAt   DateTime @default(now())
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}
