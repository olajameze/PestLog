generator client {
  provider = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  schemas = ["public"]
}

model Company {
  @@map("Company")
  @@schema("public")
  id                      String         @id @default(dbgenerated("gen_random_uuid()")) @map("id")
  name                    String?        @map("name")
  email                   String         @unique @map("email")
  phone                   String?        @map("phone")
  address                 String?        @map("address")
  website                 String?        @map("website")
  vatNumber               String?        @map("vatNumber")
  requireSignature        Boolean        @default(false) @map("requireSignature")
  requirePhotos           Boolean        @default(false) @map("requirePhotos")
  defaultReportRangeDays  Int?           @default(30)    @map("defaultReportRangeDays")
  notificationPreferences Json?          @map("notificationPreferences")
  stripeCustomerId        String?        @unique         @map("stripeCustomerId")
  subscriptionStatus      String         @default("trial") @map("subscriptionStatus")
  trialEndsAt             DateTime?      @map("trialEndsAt")
  plan                    String?        @default("trial") @map("plan")
  createdAt               DateTime       @default(now())   @map("createdAt")
  updatedAt               DateTime       @updatedAt        @map("updatedAt")
  technicians             Technician[]
  logbookEntries          LogbookEntry[]
}

model Technician {
  @@map("Technician")
  @@schema("public")
  id                      String                   @id @default(dbgenerated("gen_random_uuid()")) @map("id")
  name                    String                   @map("name")
  email                   String                   @map("email")
  companyId               String                   @map("companyId")
  createdAt               DateTime                 @default(now()) @map("createdAt")
  company                 Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  certifications          Certification[]
  logbookEntryTechnicians LogbookEntryTechnician[]
}

model Certification {
  @@map("Certification")
  @@schema("public")
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @map("id")
  technicianId String     @map("technicianId")
  fileUrl      String     @map("fileUrl")
  expiryDate   DateTime?  @map("expiryDate")
  uploadedAt   DateTime   @default(now()) @map("uploadedAt")
  technician   Technician @relation(fields: [technicianId], references: [id], onDelete: Cascade)
}

model LogbookEntry {
  @@map("LogbookEntry")
  @@schema("public")
  id                      String                   @id @default(dbgenerated("gen_random_uuid()")) @map("id")
  companyId               String                   @map("companyId")
  date                    DateTime                 @map("date")
  clientName              String                   @map("clientName")
  address                 String                   @map("address")
  treatment               String                   @map("treatment")
  notes                   String?                  @map("notes")
  photoUrl                String?                  @map("photoUrl")
  photos                  LogbookPhoto[]
  signature               String?                  @map("signature")
  rooms                   Json?                    @map("rooms")
  baitBoxesPlaced         String?                  @map("baitBoxesPlaced")
  poisonUsed              String?                  @map("poisonUsed")
  followUpDate              DateTime?              @map("followUpDate")
  internalNotes             String?                @map("internalNotes")
  productAmount             String?                @map("productAmount")
  recommendation            String?                @map("recommendation")
  baitStations              BaitStation[]
  startTime               DateTime?                @map("startTime")
  endTime                 DateTime?                @map("endTime")
  status                  String                   @default("open") @map("status")
  price                   Decimal?                 @map("price")
  logbookEntryTechnicians LogbookEntryTechnician[]
  createdAt               DateTime                 @default(now()) @map("createdAt")
  company                 Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([date])
}

model BaitStation {
  @@map("BaitStation")
  @@schema("public")
  id             String       @id @default(cuid()) @map("id")
  logbookEntryId String       @map("logbookEntryId")
  stationId      String       @map("stationId")
  location       String       @map("location")
  baitType       String?      @map("baitType")
  amount         String?      @map("amount")
  createdAt      DateTime     @default(now()) @map("createdAt")
  logbookEntry   LogbookEntry @relation(fields: [logbookEntryId], references: [id], onDelete: Cascade)
}

model LogbookEntryTechnician {
  @@map("LogbookEntryTechnician")
  @@schema("public")
  logbookEntryId String @map("logbookEntryId")
  technicianId   String @map("technicianId")
  logbookEntry   LogbookEntry @relation(fields: [logbookEntryId], references: [id], onDelete: Cascade)
  technician     Technician   @relation(fields: [technicianId], references: [id], onDelete: Cascade)

  @@id([logbookEntryId, technicianId])
}

model LogbookPhoto {
  @@map("LogbookPhoto")
  @@schema("public")
  id             String       @id @default(cuid()) @map("id")
  logbookEntryId String       @map("logbookEntryId")
  url            String       @map("url")
  createdAt      DateTime     @default(now()) @map("createdAt")
  logbookEntry   LogbookEntry @relation(fields: [logbookEntryId], references: [id], onDelete: Cascade)
}
