generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  schemas   = ["public"]
}

model Company {
  id                      String         @id @default(dbgenerated("gen_random_uuid()")) @map("id")
  name                    String?        @map("name")
  email                   String         @unique @map("email")
  phone                   String?        @map("phone")
  address                 String?        @map("address")
  website                 String?        @map("website")
  vatNumber               String?        @map("vatNumber")
  requireSignature        Boolean?       @default(false) @map("requireSignature")
  requirePhotos           Boolean?       @default(false) @map("requirePhotos")
  defaultReportRangeDays  Int?           @default(30) @map("defaultReportRangeDays")
  notificationPreferences Json?          @map("notificationPreferences")
  stripeCustomerId        String?        @unique @map("stripeCustomerId")
  subscriptionStatus      String?        @default("trial") @map("subscriptionStatus")
  trialEndsAt             DateTime?      @map("trialEndsAt") @db.Timestamptz(6)
  paymentFailedAt         DateTime?      @map("paymentFailedAt") @db.Timestamptz(6)
  paymentGraceEndsAt      DateTime?      @map("paymentGraceEndsAt") @db.Timestamptz(6)
  nonPaymentCanceledAt    DateTime?      @map("nonPaymentCanceledAt") @db.Timestamptz(6)
  retrialGrantedAt        DateTime?      @map("retrialGrantedAt") @db.Timestamptz(6)
  /** Stripe subscription current_period_end — access through this instant on paid plans. */
  subscriptionPeriodEndAt       DateTime? @map("subscriptionPeriodEndAt") @db.Timestamptz(6)
  /** True when Stripe cancel_at_period_end is set (renewal stopped; access until subscriptionPeriodEndAt). */
  subscriptionCancelAtPeriodEnd Boolean? @default(false) @map("subscriptionCancelAtPeriodEnd")
  plan                    String?        @default("trial") @map("plan")
  createdAt               DateTime?      @default(now()) @map("createdAt") @db.Timestamptz(6)
  updatedAt               DateTime?      @default(now()) @updatedAt @map("updatedAt") @db.Timestamptz(6)
  logbookEntries          LogbookEntry[]
  technicians             Technician[]

  @@map("Company")
  @@schema("public")
}

model PushSubscription {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @map("id")
  email     String   @map("email")
  endpoint  String   @unique @map("endpoint")
  p256dh    String   @map("p256dh")
  auth      String   @map("auth")
  userAgent String?  @map("userAgent")
  createdAt DateTime @default(now()) @map("createdAt") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updatedAt") @db.Timestamptz(6)

  @@index([email], map: "PushSubscription_email_idx")
  @@map("PushSubscription")
  @@schema("public")
}

model Technician {
  id                      String                   @id @default(dbgenerated("gen_random_uuid()")) @map("id")
  name                    String                   @map("name")
  email                   String                   @map("email")
  companyId               String                   @map("companyId")
  createdAt               DateTime?                @default(now()) @map("createdAt") @db.Timestamptz(6)
  certifications          Certification[]
  logbookEntryTechnicians LogbookEntryTechnician[]
  company                 Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("Technician")
  @@schema("public")
}

model Certification {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @map("id")
  technicianId String     @map("technicianId")
  fileUrl      String     @map("fileUrl")
  expiryDate   DateTime?  @map("expiryDate") @db.Timestamptz(6)
  uploadedAt   DateTime?  @default(now()) @map("uploadedAt") @db.Timestamptz(6)
  technician   Technician @relation(fields: [technicianId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("Certification")
  @@schema("public")
}

model LogbookEntry {
  id                      String                   @id @default(dbgenerated("gen_random_uuid()")) @map("id")
  companyId               String                   @map("companyId")
  date                    DateTime                 @map("date") @db.Timestamptz(6)
  clientName              String                   @map("clientName")
  address                 String                   @map("address")
  /** UK postcode (required for technician-submitted entries; optional for legacy rows). */
  postcode                String?                  @map("postcode")
  /** e.g. residential_house | residential_flat | commercial | agricultural | other */
  propertyType            String?                  @map("propertyType")
  treatment               String                   @map("treatment")
  notes                   String?                  @map("notes")
  photoUrl                String?                  @map("photoUrl")
  signature               String?                  @map("signature")
  rooms                   Json?                    @map("rooms")
  baitBoxesPlaced         String?                  @map("baitBoxesPlaced")
  poisonUsed              String?                  @map("poisonUsed")
  followUpDate            DateTime?                @map("followUpDate") @db.Timestamptz(6)
  internalNotes           String?                  @map("internalNotes")
  productAmount           String?                  @map("productAmount")
  recommendation          String?                  @map("recommendation")
  startTime               DateTime?                @map("startTime") @db.Timestamptz(6)
  endTime                 DateTime?                @map("endTime") @db.Timestamptz(6)
  status                  String?                  @default("open") @map("status")
  price                   Decimal?                 @map("price") @db.Decimal(10, 2)
  createdAt               DateTime?                @default(now()) @map("createdAt") @db.Timestamptz(6)
  baitStations            BaitStation[]
  company                 Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  logbookEntryTechnicians LogbookEntryTechnician[]
  photos                  LogbookPhoto[]

  @@map("LogbookEntry")
  @@schema("public")
}

model BaitStation {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @map("id")
  logbookEntryId String       @map("logbookEntryId")
  stationId      String       @map("stationId")
  location       String       @map("location")
  baitType       String?      @map("baitType")
  amount         String?      @map("amount")
  createdAt      DateTime?    @default(now()) @map("createdAt") @db.Timestamptz(6)
  logbookEntry   LogbookEntry @relation(fields: [logbookEntryId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("BaitStation")
  @@schema("public")
}

model LogbookEntryTechnician {
  logbookEntryId String       @map("logbookEntryId")
  technicianId   String       @map("technicianId")
  logbookEntry   LogbookEntry @relation(fields: [logbookEntryId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  technician     Technician   @relation(fields: [technicianId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([logbookEntryId, technicianId])
  @@map("LogbookEntryTechnician")
  @@schema("public")
}

model LogbookPhoto {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @map("id")
  logbookEntryId String       @map("logbookEntryId")
  url            String       @map("url")
  createdAt      DateTime?    @default(now()) @map("createdAt") @db.Timestamptz(6)
  logbookEntry   LogbookEntry @relation(fields: [logbookEntryId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("LogbookPhoto")
  @@schema("public")
}

/// Anonymised pest-activity facts derived from operational logbook data — no PII, separate conceptual layer from `LogbookEntry`.
model IntelligencePestEvent {
  id                     String   @id @default(dbgenerated("gen_random_uuid()")) @map("id")
  /// Dedup key: HMAC(companyId + entryId) — cannot be reversed to recover tenant or row without the server secret.
  sourceFingerprint      String   @unique @map("source_fingerprint")
  occurredAt             DateTime @map("occurred_at") @db.Timestamptz(6)
  pestType               String   @map("pest_type")
  infestationSeverity    String   @map("infestation_severity")
  propertyType           String   @map("property_type")
  postcodeArea           String?  @map("postcode_area")
  geoLatRounded          Float?   @map("geo_lat_rounded")
  geoLngRounded          Float?   @map("geo_lng_rounded")
  treatmentMethod        String   @map("treatment_method")
  treatmentOutcome       String   @map("treatment_outcome")
  revisitRequired        Boolean  @default(false) @map("revisit_required")
  environmentalFactors   Json?    @map("environmental_factors")
  activityScore          Int      @default(0) @map("activity_score")
  season                 String?  @map("season")
  treatmentEffectiveness String?  @map("treatment_effectiveness")
  environmentalRiskScore Int?     @map("environmental_risk_score")
  ingestedAt             DateTime @default(now()) @map("ingested_at") @db.Timestamptz(6)

  @@index([occurredAt], map: "intelligence_pest_event_occurred_at_idx")
  @@index([pestType], map: "intelligence_pest_event_pest_type_idx")
  @@index([postcodeArea], map: "intelligence_pest_event_postcode_area_idx")
  @@index([treatmentOutcome], map: "intelligence_pest_event_treatment_outcome_idx")
  @@index([propertyType], map: "intelligence_pest_event_property_type_idx")
  @@map("intelligence_pest_event")
  @@schema("public")
}

model IntelligenceAuditLog {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @map("id")
  action    String   @map("action")
  detail    Json?    @map("detail")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([createdAt], map: "intelligence_audit_log_created_at_idx")
  @@map("intelligence_audit_log")
  @@schema("public")
}
